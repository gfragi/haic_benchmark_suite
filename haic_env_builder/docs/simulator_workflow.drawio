            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;sequenceDiagram\n  actor User\n  participant Frontend\n  participant API\n  participant EnvBuilder as EnvBuilder (YAML)\n  participant Simulator\n  participant Adapter as EnvAdapter (environment plugin)\n  participant Storage as metrics/\n\n  User-&gt;&gt;Frontend: Choose scenario / parameters\n  Frontend-&gt;&gt;API: POST /api/v1/env/generate_config (optional)\n  API-&gt;&gt;EnvBuilder: Write YAML config\n  Frontend-&gt;&gt;API: POST /api/v1/simulator/simulate?name=&lt;Task&gt;_env.yaml\n  API-&gt;&gt;Simulator: simulate_environment(config_path, seed?)\n  Simulator-&gt;&gt;Adapter: create_adapter(environment, **env_params)\n  loop rollout\n    Simulator-&gt;&gt;Adapter: action_space(agent_i) + step(action_map)\n    Adapter--&gt;&gt;Simulator: decisions/events/info (+done)\n  end\n  Simulator-&gt;&gt;Storage: write &lt;Task&gt;_full_&lt;timestamp&gt;.json\n  Simulator--&gt;&gt;API: simulation_result + log_path\n  API--&gt;&gt;Frontend: JSON (metrics + decisions)\n  Frontend--&gt;&gt;User: Charts + table + “Download JSON”\n&quot;&#xa;}" id="2">
                    <mxCell style="shape=image;noLabel=1;verticalAlign=top;imageAspect=1;image=data:image/svg+xml,;" parent="1" vertex="1">
