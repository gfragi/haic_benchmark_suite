    "service": "frontend",
    "workspaceFolder": "/app",
    "remoteUser": "root",
    "customizations": {
        "vscode": {
            "extensions": [
                // ADD THE EXTENSIONS NEEDED FOR THE FRONTEND HERE
                "streetsidesoftware.code-spell-checker",
